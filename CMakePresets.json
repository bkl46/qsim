{
    "version": 3,
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build with full debug symbols",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "QSIM_BUILD_TESTS": "ON",
                "QSIM_BUILD_BENCHMARKS": "OFF",
                "QSIM_BUILD_BINDINGS": "OFF"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Release build with full optimizations",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "QSIM_BUILD_TESTS": "ON",
                "QSIM_BUILD_BENCHMARKS": "OFF",
                "QSIM_BUILD_BINDINGS": "OFF"
            }
        },
        {
            "name": "relwithdebinfo",
            "displayName": "RelWithDebInfo",
            "description": "Release with debug info",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/relwithdebinfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "QSIM_BUILD_TESTS": "ON",
                "QSIM_BUILD_BENCHMARKS": "OFF",
                "QSIM_BUILD_BINDINGS": "OFF"
            }
        }
    ]
}
